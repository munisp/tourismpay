  "panels": [
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(tourismpay_http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Latency P95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(tourismpay_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "tourismpay_active_connections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Wallet Transactions Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "tourismpay_wallet_transactions_total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Wallet Volume (NGN)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "tourismpay_wallet_volume_ngn",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyNGN"
        }
      }
    },
    {
      "title": "BIS Investigations Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "tourismpay_bis_investigations_total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "KYB Applications Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "tourismpay_kyb_applications_total",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Settlement Volume (NGN)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "tourismpay_settlement_volume_ngn",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyNGN"
        }
      }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(tourismpay_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "{{method}} {{route}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "title": "Infrastructure Health",
