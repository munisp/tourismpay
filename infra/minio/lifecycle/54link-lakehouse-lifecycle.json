{
  "Rules": [
    {
      "ID": "tier-hot-to-warm-after-30-days",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "raw/"
      },
      "Transitions": [
        {
          "Days": 30,
          "StorageClass": "STANDARD_IA"
        }
      ]
    },
    {
      "ID": "tier-warm-to-cold-after-90-days",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "raw/"
      },
      "Transitions": [
        {
          "Days": 90,
          "StorageClass": "GLACIER"
        }
      ]
    },
    {
      "ID": "expire-raw-data-after-7-years",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "raw/"
      },
      "Expiration": {
        "Days": 2555
      }
    },
    {
      "ID": "expire-temp-processing-files",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "tmp/"
      },
      "Expiration": {
        "Days": 3
      }
    },
    {
      "ID": "expire-old-reports",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "reports/"
      },
      "Expiration": {
        "Days": 365
      }
    },
    {
      "ID": "cleanup-incomplete-multipart",
      "Status": "Enabled",
      "Filter": {
        "Prefix": ""
      },
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 7
      }
    }
  ]
}
