{
  "Rules": [
    {
      "ID": "expire-old-screenshots",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "screenshots/"
      },
      "Expiration": {
        "Days": 90
      }
    },
    {
      "ID": "expire-temp-uploads",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "tmp/"
      },
      "Expiration": {
        "Days": 1
      }
    },
    {
      "ID": "transition-old-screenshots-to-glacier",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "screenshots/"
      },
      "Transitions": [
        {
          "Days": 30,
          "StorageClass": "GLACIER"
        }
      ]
    }
  ]
}
