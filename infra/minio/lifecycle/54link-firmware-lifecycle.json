{
  "Rules": [
    {
      "ID": "expire-old-firmware-versions",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "firmware/"
      },
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 365
      }
    },
    {
      "ID": "delete-failed-uploads",
      "Status": "Enabled",
      "Filter": {
        "Prefix": ""
      },
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 7
      }
    }
  ]
}
