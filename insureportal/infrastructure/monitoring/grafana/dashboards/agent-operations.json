{
  "title": "InsurePortal POS — Agent Operations",
  "uid": "insureportal-agent-ops",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "60s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Agent Float Balances (NGN)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "topk(20, pos_agent_float_balance_ngn)",
          "legendFormat": "{{agent_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyNGN",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 10000, "color": "yellow" },
              { "value": 50000, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Agents Below Minimum Float",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "count(pos_agent_float_balance_ngn < 50000)",
          "legendFormat": "Agents Low"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Pending Float Top-Up Requests",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "pos_float_topup_pending_count",
          "legendFormat": "Pending"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "Transactions per Agent (24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, increase(pos_transactions_by_agent_total[24h]))",
          "legendFormat": "{{agent_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Agent Login Activity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_agent_logins_total[5m])",
          "legendFormat": "Logins/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 6,
      "title": "Settlement Status",
      "type": "stat",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pos_settlement_last_run_timestamp",
          "legendFormat": "Last Settlement"
        },
        {
          "expr": "pos_settlement_unsettled_amount_ngn",
          "legendFormat": "Unsettled Amount"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
