{
  "title": "InsurePortal POS — MDM Fleet Overview",
  "uid": "insureportal-mdm-fleet",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "tags": ["mdm", "fleet", "devices", "insureportal"],
  "panels": [
    {
      "id": 1,
      "title": "Fleet Online Rate",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "pos_mdm_online_devices_total / pos_mdm_registered_devices_total * 100",
          "legendFormat": "Online %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true
      }
    },
    {
      "id": 2,
      "title": "Device Status Summary",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "pos_mdm_registered_devices_total",
          "legendFormat": "Total Registered"
        },
        { "expr": "pos_mdm_online_devices_total", "legendFormat": "Online" },
        { "expr": "pos_mdm_offline_devices_total", "legendFormat": "Offline" },
        {
          "expr": "pos_mdm_rooted_devices_total",
          "legendFormat": "Rooted/Compromised"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Rooted/Compromised" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Compliance Violations (last 24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "increase(pos_mdm_compliance_violations_total{severity=\"critical\"}[24h])",
          "legendFormat": "Critical"
        },
        {
          "expr": "increase(pos_mdm_compliance_violations_total{severity=\"warning\"}[24h])",
          "legendFormat": "Warning"
        },
        {
          "expr": "increase(pos_mdm_tamper_events_total[24h])",
          "legendFormat": "Tamper Events"
        },
        {
          "expr": "increase(pos_mdm_geofence_violations_total[24h])",
          "legendFormat": "Geofence Violations"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tamper Events" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Device Heartbeat Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_mdm_heartbeats_total[5m])",
          "legendFormat": "Heartbeats/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "title": "Compliance Violations Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_mdm_compliance_violations_total{severity=\"critical\"}[5m])",
          "legendFormat": "Critical"
        },
        {
          "expr": "rate(pos_mdm_compliance_violations_total{severity=\"warning\"}[5m])",
          "legendFormat": "Warning"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "OTA Update Progress",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_ota_update_attempts_total[5m])",
          "legendFormat": "Attempts/s"
        },
        {
          "expr": "rate(pos_ota_update_successes_total[5m])",
          "legendFormat": "Successes/s"
        },
        {
          "expr": "rate(pos_ota_update_failures_total[5m])",
          "legendFormat": "Failures/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "title": "Firmware Version Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pos_mdm_devices_by_firmware_version",
          "legendFormat": "v{{firmware_version}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] }
    },
    {
      "id": 8,
      "title": "Offline Devices by Duration",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sort_desc((time() - pos_mdm_last_heartbeat_timestamp) > 3600)",
          "legendFormat": "{{device_id}} ({{terminal_id}})",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Offline Duration" },
              { "id": "unit", "value": "s" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Offline Duration", "desc": true }]
      }
    }
  ]
}
