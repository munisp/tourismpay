# TourismPay — Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tourismpay_user:your_password@localhost:5432/tourismpay

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long
OWNER_OPEN_ID=owner_open_id_here

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tourismpay.com

# ─── SMTP (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tourismpay.com

# ─── External Services (optional) ─────────────────────────────────────────────
SETTLEMENT_SERVICE_URL=
PAYMENT_SWITCH_URL=
BIS_CORE_URL=
BIS_AI_URL=
KYB_SERVICE_URL=
