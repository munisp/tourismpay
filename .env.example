# TourismPay — Environment Variables
# Copy this file to .env and fill in your values

# ─── Database (TypeScript / Drizzle) ─────────────────────────────────────────
DATABASE_URL=postgresql://tourismpay_user:your_password@localhost:5432/tourismpay

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars-long
OWNER_OPEN_ID=owner_open_id_here

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tourismpay.com

# ─── SMTP (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tourismpay.com

# ─── Security / Rate Limiting ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100

# ─── PII Encryption ─────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ─── Go Settlement Service ───────────────────────────────────────────────────
GO_DATABASE_URL=postgresql://tourismpay_user:your_password@localhost:5432/tourismpay_settlement
SETTLEMENT_API_KEY=your-settlement-api-key
SETTLEMENT_SERVICE_URL=http://localhost:8081

# ─── Python ML Services ─────────────────────────────────────────────────────
ML_DATABASE_URL=postgresql://tourismpay_user:your_password@localhost:5432/tourismpay_settlement
SERVICE_API_KEY=your-python-service-api-key
BIS_AI_ENGINE_URL=http://localhost:8001
FRAUD_ML_SERVICE_URL=http://localhost:8002
COMPLIANCE_RISK_ENGINE_URL=http://localhost:8003
EXCHANGE_RATE_ML_URL=http://localhost:8004
PDF_REPORT_GENERATOR_URL=http://localhost:8005

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_PAYMENT_SWITCH_PORTAL_URL=http://localhost:3001

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=tourismpay

# ─── TigerBeetle ────────────────────────────────────────────────────────────
TIGERBEETLE_ADDRESSES=127.0.0.1:3001

# ─── Mojaloop ───────────────────────────────────────────────────────────────
MOJALOOP_HUB_URL=
MOJALOOP_DFSP_ID=tourismpay

# ─── Keycloak OIDC ──────────────────────────────────────────────────────────
KEYCLOAK_URL=
KEYCLOAK_REALM=tourismpay
KEYCLOAK_CLIENT_ID=tourismpay-pwa
KEYCLOAK_CLIENT_SECRET=

# ─── Permify Authorization ──────────────────────────────────────────────────
PERMIFY_ENDPOINT=
PERMIFY_TENANT_ID=tourismpay
PERMIFY_API_KEY=

# ─── OpenSearch ─────────────────────────────────────────────────────────────
OPENSEARCH_URL=
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_VERIFY_SSL=true

# ─── APISIX Gateway ────────────────────────────────────────────────────────
APISIX_ADMIN_URL=
APISIX_ADMIN_KEY=

# ─── Dapr ───────────────────────────────────────────────────────────────────
DAPR_HTTP_PORT=3500
DAPR_APP_ID=tourismpay-pwa
DAPR_PUBSUB_NAME=tourismpay-pubsub
DAPR_STATE_STORE=tourismpay-state

# ─── Fluvio ────────────────────────────────────────────────────────────────
FLUVIO_ENDPOINT=

# ─── Lakehouse / Trino ──────────────────────────────────────────────────────
LAKEHOUSE_URL=
TRINO_URL=

# ─── External Services (optional) ───────────────────────────────────────────
PAYMENT_SWITCH_URL=
BIS_CORE_URL=
BIS_AI_URL=
KYB_SERVICE_URL=
KYC_SERVICE_URL=
KYC_API_KEY=
COPILOT_URL=
REGISTRY_URL=
REGISTRY_SERVICE_URL=

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DB_POOL_SIZE=20
LOCAL_DATABASE_URL=postgresql://tourismpay_user:your_password@localhost:5432/tourismpay

# ─── Go Settlement Service (extended) ───────────────────────────────────────
GO_SETTLEMENT_URL=http://localhost:8081
GO_SERVICE_JWT=your-go-service-jwt-secret
SETTLEMENT_HOST=localhost:8081

# ─── Rust KYC Service ──────────────────────────────────────────────────────
KYC_HOST=localhost:8090
ML_HOST=localhost:8002

# ─── OAuth / Keycloak (extended) ───────────────────────────────────────────
OAUTH_SERVER_URL=http://localhost:8080/realms/tourismpay

# ─── Frontend (Vite, extended) ─────────────────────────────────────────────
VITE_APP_ID=tourismpay-pwa
VITE_APP_ORIGIN=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3001

# ─── PWA Hosts (HA cluster) ───────────────────────────────────────────────
PWA_HOST=localhost:3000
PWA_HOST_1=localhost:3000
PWA_HOST_2=localhost:3001
PWA_HOST_3=localhost:3002
PS_HOST_1=localhost:4000
PS_HOST_2=localhost:4001

# ─── Kafka (HA cluster) ───────────────────────────────────────────────────
KAFKA_BROKER_1_HOST=localhost:9092
KAFKA_BROKER_2_HOST=localhost:9093
KAFKA_BROKER_3_HOST=localhost:9094
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ─── Redis (HA / Sentinel / Cluster) ──────────────────────────────────────
REDIS_MODE=standalone
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_PASSWORD=
REDIS_SENTINELS=
REDIS_SENTINEL_1_HOST=localhost:26379
REDIS_SENTINEL_2_HOST=localhost:26380
REDIS_SENTINEL_3_HOST=localhost:26381
REDIS_CLUSTER_1_HOST=localhost:7000
REDIS_CLUSTER_2_HOST=localhost:7001
REDIS_CLUSTER_3_HOST=localhost:7002
REDIS_CLUSTER_4_HOST=localhost:7003
REDIS_CLUSTER_5_HOST=localhost:7004
REDIS_CLUSTER_6_HOST=localhost:7005

# ─── TigerBeetle (HA cluster) ─────────────────────────────────────────────
TB_CLUSTER_ID=0
TB_HOST_1=127.0.0.1:3001
TB_HOST_2=127.0.0.1:3002
TB_HOST_3=127.0.0.1:3003
TB_REPLICA_0=127.0.0.1:3001
TB_REPLICA_1=127.0.0.1:3002
TB_REPLICA_2=127.0.0.1:3003
TB_REPLICA_3=127.0.0.1:3004
TB_REPLICA_4=127.0.0.1:3005
TB_REPLICA_5=127.0.0.1:3006

# ─── Temporal (HA cluster) ────────────────────────────────────────────────
TEMPORAL_HOST_1=localhost:7233
TEMPORAL_HOST_2=localhost:7234
TEMPORAL_HOST_3=localhost:7235
TEMPORAL_TLS=false

# ─── etcd (distributed config) ────────────────────────────────────────────
ETCD_HOST_1=localhost:2379
ETCD_HOST_2=localhost:2380
ETCD_HOST_3=localhost:2381

# ─── Fluvio (extended) ───────────────────────────────────────────────────
FLUVIO_PROFILE_PATH=

# ─── BIS (extended) ──────────────────────────────────────────────────────
BIS_GATEWAY_URL=http://localhost:8010
BIS_OSINT_URL=http://localhost:8011

# ─── Backup / DR ─────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_WAL_ARCHIVING=true
BACKUP_CROSS_REGION=false

# ─── Africa's Talking (SMS gateway) ──────────────────────────────────────
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# ─── SMS / WhatsApp ──────────────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_SENDER_ID=TourismPay
SMS_SHORT_CODE=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Built.in Forge ─────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Foreign Tourist Wallet Loading ──────────────────────────────────────

# SWIFT/SEPA/ACH Wire Transfer (IMTO Partner)
WIRE_IMTO_PARTNER=flutterwave_international
WIRE_SEPA_IBAN=
WIRE_SEPA_BIC=
WIRE_ACH_ACCOUNT=
WIRE_ACH_ROUTING=
WIRE_UK_ACCOUNT=
WIRE_UK_SORT_CODE=
WIRE_SWIFT_IBAN=
WIRE_SWIFT_BIC=
WIRE_WEBHOOK_SECRET=

# Partner Remittance Service
PARTNER_REMITTANCE_URL=http://localhost:8085
WISE_API_BASE=https://api.sandbox.transferwise.tech
WISE_API_KEY=
WISE_WEBHOOK_SECRET=
REVOLUT_API_BASE=https://sandbox-b2b.revolut.com/api/1.0
REVOLUT_API_KEY=
REVOLUT_WEBHOOK_SECRET=
REMITLY_API_BASE=https://api.remitly.io/v3
REMITLY_API_KEY=
REMITLY_WEBHOOK_SECRET=
LEMFI_API_BASE=https://api.lemfi.com/v1
LEMFI_API_KEY=
LEMFI_WEBHOOK_SECRET=

# Agent Banking / Airport Kiosk
AGENT_KYC_PROVIDER=smile_identity
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=
NIMC_NIN_API_URL=https://api.nimc.gov.ng/v1
NIMC_NIN_API_KEY=
NIBSS_BVN_API_URL=https://api.nibss-plc.com.ng/bvn/v2
NIBSS_BVN_API_KEY=

# USSD
USSD_SHORTCODE=*555#
USSD_PROVIDER=africas_talking
AFRICAS_TALKING_USSD_CODE=*555#

# ─── Direct Bank Partner SWIFT Integration ──────────────────────────────
# GTBank (Nigerian SWIFT member — GTBINGLA)
GTBANK_API_BASE=https://api.gtbank.com/v1
GTBANK_API_KEY=
GTBANK_WEBHOOK_SECRET=
GTBANK_VIRTUAL_IBAN_PREFIX=NG07

# Access Bank (Pan-African SWIFT member — ABORNGLA)
ACCESS_BANK_API_BASE=https://api.accessbankplc.com/v2
ACCESS_BANK_API_KEY=
ACCESS_BANK_WEBHOOK_SECRET=

# CurrencyCloud / Visa (SWIFT member — CABORB22)
CURRENCYCLOUD_API_BASE=https://devapi.currencycloud.com/v2
CURRENCYCLOUD_LOGIN_ID=
CURRENCYCLOUD_API_KEY=
CURRENCYCLOUD_ENVIRONMENT=sandbox
CURRENCYCLOUD_WEBHOOK_SECRET=

# Banking Circle (European SWIFT member — BKCHDKKK)
BANKING_CIRCLE_API_BASE=https://sandbox.bankingcircle.com/api/v1
BANKING_CIRCLE_USERNAME=
BANKING_CIRCLE_PASSWORD=
BANKING_CIRCLE_WEBHOOK_SECRET=

# ─── Travel Readiness & Gap Resolution ───────────────────────────────────

# eSIM Vendor Integration (Airalo, Holafly, Nomad)
AIRALO_API_BASE=https://sandbox-partners-api.airalo.com/v2
AIRALO_API_KEY=
HOLAFLY_API_BASE=https://api.holafly.com/v1
HOLAFLY_API_KEY=
NOMAD_API_BASE=https://api.getnomad.app/v1
NOMAD_API_KEY=

# Pre-Travel Risk ML Service
ML_SERVICE_URL=http://localhost:8001
TRAVEL_RISK_MODEL_VERSION=1.0.0

# Currency Corridor Expansion
BRL_ONRAMP_PROVIDER=wise  # Pix integration via Wise
INR_ONRAMP_PROVIDER=wise  # UPI integration via Wise
CNY_ONRAMP_PROVIDER=alipay  # Alipay cross-border

# ─── K8s Pod Identity ───────────────────────────────────────────────────
POD_NAME=tourismpay-server-0
