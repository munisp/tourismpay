{
  "name": "TourismPay",
  "displayName": "TourismPay",
  "expo": {
    "name": "TourismPay",
    "slug": "tourismpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tourismpay.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "TourismPay uses the camera for QR code scanning and document verification",
        "NSFaceIDUsageDescription": "TourismPay uses Face ID for secure authentication",
        "NSLocationWhenInUseUsageDescription": "TourismPay uses your location to show nearby merchants and tourist attractions",
        "NSPhotoLibraryUsageDescription": "TourismPay needs access to your photos for document upload"
      },
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_KEY"
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.tourismpay.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "NFC",
        "READ_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_KEY"
        }
      },
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "15.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "tourismpay-mobile"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/tourismpay-mobile"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
