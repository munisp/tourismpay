{
  "expo": {
    "name": "TourismPay",
    "slug": "tourismpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tourismpay.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for QR code scanning and document verification",
        "NSFaceIDUsageDescription": "Used for biometric authentication"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.tourismpay.mobile",
      "permissions": ["CAMERA", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      ["expo-camera", { "cameraPermission": "Used for QR code scanning" }]
    ],
    "scheme": "tourismpay",
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "tourismpay-mobile" }
    }
  }
}
