{
  "annotations": {"list": []},
  "editable": true,
  "title": "NGApp Platform - Production Dashboard",
  "uid": "ngapp-prod",
  "version": 1,
  "panels": [
    {
      "title": "Service Health Overview",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "count(up{job=~\"ngapp-.*\"} == 1)", "legendFormat": "Healthy"}]
    },
    {
      "title": "Total Request Rate (req/s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{job=~\"ngapp-.*\"}[5m]))"}]
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(http_requests_total{job=~\"ngapp-.*\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=~\"ngapp-.*\"}[5m])) * 100"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "yellow"}, {"value": 5, "color": "red"}]}}}
    },
    {
      "title": "P99 Latency (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"ngapp-.*\"}[5m])) by (le)) * 1000"}]
    },
    {
      "title": "Request Rate by Service",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum(rate(http_requests_total{job=~\"ngapp-.*\"}[5m])) by (service)", "legendFormat": "{{service}}"}]
    },
    {
      "title": "Latency Distribution by Service",
      "type": "heatmap",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "sum(rate(http_request_duration_seconds_bucket{job=~\"ngapp-.*\"}[5m])) by (le, service)"}]
    },
    {
      "title": "Database Connections",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
      "targets": [
        {"expr": "ngapp_db_pool_active{job=~\"ngapp-.*\"}", "legendFormat": "Active - {{service}}"},
        {"expr": "ngapp_db_pool_idle{job=~\"ngapp-.*\"}", "legendFormat": "Idle - {{service}}"}
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
      "targets": [{"expr": "kafka_consumer_group_lag{group=~\"ngapp-.*\"}", "legendFormat": "{{group}} - {{topic}}"}]
    },
    {
      "title": "Redis Operations/s",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 12},
      "targets": [{"expr": "sum(rate(redis_commands_total{service=~\"ngapp-.*\"}[5m])) by (cmd)", "legendFormat": "{{cmd}}"}]
    },
    {
      "title": "Claims Processing Pipeline",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "targets": [
        {"expr": "sum(rate(ngapp_claims_submitted_total[5m]))", "legendFormat": "Submitted"},
        {"expr": "sum(rate(ngapp_claims_approved_total[5m]))", "legendFormat": "Approved"},
        {"expr": "sum(rate(ngapp_claims_rejected_total[5m]))", "legendFormat": "Rejected"},
        {"expr": "sum(rate(ngapp_claims_escalated_total[5m]))", "legendFormat": "Escalated"}
      ]
    },
    {
      "title": "Policy Issuance Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
      "targets": [
        {"expr": "sum(rate(ngapp_policies_issued_total[5m])) by (product_type)", "legendFormat": "{{product_type}}"}
      ]
    }
  ]
}
