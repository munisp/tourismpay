{
  "title": "54Link POS — Transactions Overview",
  "uid": "54link-transactions",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Transaction Rate (TPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_transactions_total[1m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Transaction Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pos_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(pos_transaction_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1.5, "color": "yellow" },
              { "value": 3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Transaction Error Rate",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "rate(pos_transactions_total{status='failed'}[5m]) / rate(pos_transactions_total[5m]) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 2, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Transactions (24h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "increase(pos_transactions_total[24h])",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Transaction Volume by Type",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (type) (increase(pos_transactions_total[24h]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Fraud Alerts Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(pos_fraud_alerts_total[5m])",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "Active Agents",
      "type": "stat",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "pos_active_agents_total",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Total Float (NGN)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(pos_agent_float_balance_ngn)",
          "legendFormat": "Total Float"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyNGN" }
      }
    }
  ]
}
