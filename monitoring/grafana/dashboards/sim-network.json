{
  "title": "54Link POS — SIM Network Quality",
  "uid": "54link-sim-network",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Average RSSI by Terminal",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "avg by (terminal_id, sim_slot) (pos_sim_rssi_dbm)",
          "legendFormat": "{{terminal_id}} SIM{{sim_slot}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "thresholds": {
            "steps": [
              { "value": -90, "color": "red" },
              { "value": -70, "color": "yellow" },
              { "value": -50, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "SIM Failover Events",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "increase(pos_sim_failovers_total[5m])",
          "legendFormat": "{{terminal_id}} — {{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 3,
      "title": "Packet Loss % by Terminal",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "pos_sim_packet_loss_percent",
          "legendFormat": "{{terminal_id}} SIM{{sim_slot}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 20, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active SIM Carrier Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (carrier) (pos_sim_active_carrier)",
          "legendFormat": "{{carrier}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Latency by SIM Slot",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "pos_sim_latency_ms",
          "legendFormat": "{{terminal_id}} SIM{{sim_slot}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1500, "color": "yellow" },
              { "value": 3000, "color": "red" }
            ]
          }
        }
      }
    }
  ]
}
