{
  "dashboard": {
    "title": "Africa GDS — Operations Dashboard",
    "uid": "gds-ops",
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(gds_http_requests_total[5m])) by (method)",
            "legendFormat": "{{method}}"
          }
        ]
      },
      {
        "title": "Error Rate (%)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(gds_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(gds_http_requests_total[5m])) * 100",
            "legendFormat": "5xx Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "title": "P50 / P95 / P99 Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(gds_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(gds_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(gds_http_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P99"
          }
        ]
      },
      {
        "title": "Active Connections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(gds_http_active_connections)",
            "legendFormat": "Active"
          }
        ]
      },
      {
        "title": "PNRs Created",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "sum(increase(gds_pnr_created_total[24h]))",
            "legendFormat": "Last 24h"
          }
        ]
      },
      {
        "title": "Bookings Confirmed",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "sum(increase(gds_bookings_confirmed_total[24h]))",
            "legendFormat": "Last 24h"
          }
        ]
      },
      {
        "title": "Cache Hit Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(gds_cache_hits_total[5m])) / (sum(rate(gds_cache_hits_total[5m])) + sum(rate(gds_cache_misses_total[5m]))) * 100",
            "legendFormat": "Hit %"
          }
        ]
      },
      {
        "title": "Service Health",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "up{job=~\"gds-.*\"}",
            "format": "table",
            "instant": true
          }
        ]
      },
      {
        "title": "PostgreSQL Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "pg_stat_database_numbackends{datname=\"gds\"}",
            "legendFormat": "Active Connections"
          }
        ]
      },
      {
        "title": "Redis Memory",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          {
            "expr": "redis_memory_used_bytes / 1048576",
            "legendFormat": "Used (MB)"
          }
        ]
      },
      {
        "title": "Kafka Consumer Lag",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
        "targets": [
          {
            "expr": "kafka_consumer_group_lag",
            "legendFormat": "{{topic}} — {{group}}"
          }
        ]
      },
      {
        "title": "Commission Splits / Settlement Sagas",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
        "targets": [
          {
            "expr": "rate(gds_commission_splits_total[5m]) * 60",
            "legendFormat": "Splits/min"
          },
          {
            "expr": "rate(gds_settlement_sagas_total[5m]) * 60",
            "legendFormat": "Sagas/min"
          }
        ]
      }
    ]
  }
}
