{
  "name": "@tourismpay/gds-standalone",
  "version": "1.1.0",
  "description": "Africa-first Global Distribution System — Standalone white-label deployment",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/lib/migrations.ts",
    "backup": "bash scripts/backup/backup.sh",
    "load-test": "k6 run k6/load-test.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "zod": "^3.22.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
