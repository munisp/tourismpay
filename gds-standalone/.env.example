# Africa-first GDS — Standalone Configuration
# Copy to .env and customize for your deployment.

# Server
GDS_PORT=8090
NODE_ENV=production

# Multi-Tenancy
GDS_MULTI_TENANT=false
GDS_DEFAULT_TENANT=default

# Authentication (Keycloak / OIDC)
GDS_AUTH_ISSUER=http://localhost:8180/realms/gds-agents
GDS_AUTH_AUDIENCE=gds-api
GDS_AUTH_JWKS_URI=http://localhost:8180/realms/gds-agents/protocol/openid-connect/certs
GDS_AUTH_API_KEY_ENABLED=true

# CORS
GDS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
GDS_DATABASE_URL=postgresql://gds_user:gds_pass@localhost:5433/gds

# Redis
GDS_REDIS_URL=redis://localhost:6380/1

# Kafka
GDS_KAFKA_BROKERS=localhost:9093

# Upstream Services
GDS_ENGINE_URL=http://localhost:8080
GDS_SEARCH_URL=http://localhost:8010
GDS_ANALYTICS_URL=http://localhost:8011

# TigerBeetle (settlement ledger)
TIGERBEETLE_ADDRESSES=localhost:3000

# Mojaloop (cross-border payments)
MOJALOOP_HUB_URL=http://localhost:4000

# Rate Limiting
GDS_RATE_LIMIT_WINDOW=60000
GDS_RATE_LIMIT_MAX=100

# White-Label Branding
GDS_BRAND_NAME=Africa GDS
GDS_BRAND_LOGO_URL=
GDS_BRAND_PRIMARY_COLOR=#6366f1
