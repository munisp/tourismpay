# Africa-first GDS — Standalone Configuration
# Copy to .env and customize for your deployment.
#
# Architecture: APISIX (gateway) + Keycloak (auth) + OpenAppSec (WAF)
# No Express gateway — routing/auth/rate-limit handled by APISIX + Keycloak plugins.

# ═══ Database ═══
GDS_DB_PASSWORD=gds_pass

# ═══ APISIX Gateway ═══
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1
GDS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ═══ Keycloak ═══
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_GDS_CLIENT_SECRET=change-me-in-production

# ═══ Backend Services ═══
# Go Engine (reservation, settlement, distribution)
TIGERBEETLE_ADDRESSES=localhost:3000
MOJALOOP_HUB_URL=http://localhost:4000
PERMIFY_ENDPOINT=localhost:3478

# Python Search (OpenSearch-powered)
OPENSEARCH_URL=http://localhost:9200

# Python Analytics (Lakehouse pipeline)
LAKEHOUSE_URL=http://localhost:8181

# ═══ Event Streaming ═══
KAFKA_BROKERS=localhost:9093

# ═══ White-Label Branding ═══
# Customize these for your deployment
GDS_BRAND_NAME=Africa GDS
GDS_BRAND_LOGO_URL=
GDS_BRAND_PRIMARY_COLOR=#6366f1
