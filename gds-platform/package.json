{
  "name": "tourismpay-gds-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Africa-first Global Distribution System — standalone platform integrating with TourismPay via API",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/index.ts",
    "dev:client": "cd client && npx vite --port 4001",
    "build": "cd client && npx vite build && cd .. && npx tsc --noEmit",
    "start": "NODE_ENV=production node dist/server/index.js",
    "typecheck": "npx tsc --noEmit"
  },
  "dependencies": {
    "@trpc/client": "^10.45.0",
    "@trpc/react-query": "^10.45.0",
    "@trpc/server": "^10.45.0",
    "@tanstack/react-query": "^5.0.0",
    "express": "^4.18.2",
    "zod": "^3.22.0",
    "jsonwebtoken": "^9.0.0",
    "cors": "^2.8.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "superjson": "^2.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
