# GDS Platform — Environment Variables
# Copy to .env and adjust as needed

# GDS Server
GDS_PORT=4000
GDS_JWT_SECRET=gds-dev-secret-32chars-minimum!!
GDS_CORS_ORIGIN=*

# TourismPay API Integration (the upstream service)
TOURISMPAY_API_URL=http://localhost:3000
TOURISMPAY_API_KEY=

# Go Microservice (tax/tipping engine)
GDS_GO_PORT=4002

# Python ML Service (forecasting/recommendations)
GDS_PYTHON_PORT=4003

# Database (shared with TourismPay in dev)
DATABASE_URL=postgresql://tourismpay_user:testpass123@localhost:5432/tourismpay
