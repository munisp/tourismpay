<?xml version="1.0" encoding="utf-8"?>
<!--
  54Link MDM Device Admin Policy
  Declares the device admin capabilities required for remote management.
  Referenced in AndroidManifest.xml via android:resource="@xml/mdm_device_admin"
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <!-- Required for MDM WIPE command -->
        <wipe-data />
        <!-- Required for MDM LOCK command -->
        <force-lock />
        <!-- Required for compliance policy: enforce encryption -->
        <encrypted-storage />
        <!-- Required for compliance policy: disable camera in secure zones -->
        <disable-camera />
        <!-- Required for compliance policy: enforce screen lock timeout -->
        <limit-password />
        <!-- Required for compliance policy: enforce password complexity -->
        <watch-login />
        <!-- Required for compliance policy: reset password remotely -->
        <reset-password />
    </uses-policies>
</device-admin>
