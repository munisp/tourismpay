FROM rust:1.80-alpine AS builder
RUN apk add --no-cache musl-dev
WORKDIR /app

COPY redis-cache/ redis-cache/
COPY tigerbeetle-ledger/ tigerbeetle-ledger/
COPY fluvio-stream/ fluvio-stream/
COPY unified-streaming/ unified-streaming/

WORKDIR /app/unified-streaming
RUN cargo build --release

FROM alpine:3.19
RUN apk add --no-cache ca-certificates curl
COPY --from=builder /app/unified-streaming/target/release/rust-streaming /usr/local/bin/rust-streaming
EXPOSE 8110
CMD ["rust-streaming"]
